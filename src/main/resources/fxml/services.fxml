<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.carservicecenter_ds.controllers.adminServiceController">

   <children>
      <HBox prefHeight="100.0" style="-fx-background-color: transparent; -fx-border-color: #e6e6e6; -fx-border-width: 0 0 1px 0;">

         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS">
               <children>
                  <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #12372a;" text="Services" />
               </children>
            </HBox>

            <HBox alignment="CENTER_RIGHT" prefHeight="100.0" style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS">
               <children>
                  <Button fx:id="addService" mnemonicParsing="false" onAction="#addService" style="-fx-background-color: #12372a; -fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 14px; -fx-padding: 8px 16px; -fx-border-radius: 4px; -fx-background-radius: 4px; -fx-cursor: hand;" text="Add service" />
               </children>
            </HBox>
         </children>

         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>

      </HBox>

      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="mechanicScrollpane" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
         <content>
            <FlowPane fx:id="servicesRoot" alignment="TOP_LEFT" hgap="20.0" vgap="20.0">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </FlowPane>
         </content>
      </ScrollPane>
   </children>
</VBox>
