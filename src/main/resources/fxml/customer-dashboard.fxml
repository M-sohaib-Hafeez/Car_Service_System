<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="590.0" prefWidth="850.0" style="-fx-background-color: #f5f2ec;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.carservicecenter_ds.controllers.CustomerController">

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT"  prefHeight="60.0" AnchorPane.topAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" style="-fx-background-color: #12372a; -fx-background-radius: 10;">
        <padding>
            <Insets left="20.0" right="20.0" />
        </padding>
        <Label fx:id="welcomeLabel" text="Welcome Back, Customer!" textFill="#f0fdf4">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="logoutBtn" mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Logout">
            <font>
                <Font size="12.0" />
            </font>
        </Button>
    </HBox>

    <!-- Main Content Area -->
    <ScrollPane fitToWidth="true"
                AnchorPane.topAnchor="80.0"
                AnchorPane.leftAnchor="10.0"
                AnchorPane.rightAnchor="10.0"
                AnchorPane.bottomAnchor="10.0" style="-fx-background: transparent; -fx-background-color: transparent;">
        <VBox spacing="15.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
            </padding>

            <!-- Current Service Status Card -->
            <VBox fx:id="currentServiceCard" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" visible="false">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                <Label text="🔧 Current Service" textFill="#12372a">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <HBox spacing="20.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label fx:id="currentServiceName" text="Oil Change Service" textFill="#1f2933">
                            <font>
                                <Font name="System Bold" size="15.0" />
                            </font>
                        </Label>
                        <Label fx:id="currentVehicleInfo" text="2020 Toyota Camry (ABC-123)" textFill="#4b5563">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                        <HBox spacing="10.0">
                            <Label fx:id="currentStatusLabel" text="Status: PENDING" textFill="#FFA500">
                                <font>
                                    <Font name="System Bold" size="13.0" />
                                </font>
                            </Label>
                            <Label fx:id="currentPriorityLabel" text="Priority: Normal" textFill="#1E90FF">
                                <font>
                                    <Font name="System Bold" size="13.0" />
                                </font>
                            </Label>
                        </HBox>
                    </VBox>

                    <VBox alignment="CENTER_RIGHT" spacing="5.0">
                        <Label fx:id="currentCostLabel" text="₨ 2,500" textFill="#12372a">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <Label fx:id="currentScheduledTime" text="Scheduled: Jan 5, 2:00 PM" textFill="#4b5563">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </VBox>
                </HBox>

                <Separator />

                <Label fx:id="currentNotes" text="Notes: Regular maintenance checkup" textFill="#4b5563" wrapText="true">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
            </VBox>

            <!-- Queue Position Card -->
            <HBox fx:id="queueCard" alignment="CENTER" spacing="15.0" style="-fx-background-color: #86efac; -fx-background-radius: 10; -fx-padding: 15;" visible="false">
                <Label text="📋 Your Position in Queue:" textFill="#12372a">
                    <font>
                        <Font name="System Bold" size="15.0" />
                    </font>
                </Label>
                <Label fx:id="queuePositionLabel" text="#3" textFill="#12372a">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <Label text="(Estimated wait: 45 minutes)" textFill="#15803d">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Label>
            </HBox>

            <!-- No Active Service Message -->
            <VBox fx:id="noServiceCard" alignment="CENTER" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" visible="true">
                <Label text="✨ No Active Services" textFill="#12372a">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <Label text="You don't have any active service appointments at the moment." textFill="#6b7280">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Label>
                <Button mnemonicParsing="false" onAction="#openBookingForm" style="-fx-background-color: linear-gradient(to right, #1db954, #16a34a); -fx-text-fill: #0e0e0e; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 10 30; -fx-cursor: hand;" text="Book New Appointment">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
            </VBox>

            <!-- Quick Actions -->
            <HBox spacing="15.0">
                <Button mnemonicParsing="false" onAction="#openBookingForm" prefHeight="45.0" prefWidth="270.0" style="-fx-background-color: #12372a; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="📅 Book New Appointment">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Button mnemonicParsing="false" onAction="#refreshDashboard" prefHeight="45.0" prefWidth="270.0" style="-fx-background-color: #1db954; -fx-text-fill: #0e0e0e; -fx-background-radius: 8; -fx-cursor: hand;" text="🔄 Refresh Status">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Button mnemonicParsing="false" onAction="#viewHistory" prefHeight="45.0" prefWidth="270.0" style="-fx-background-color: #86efac; -fx-text-fill: #0e0e0e; -fx-background-radius: 8; -fx-cursor: hand;" text="📜 View History">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </HBox>

            <!-- Appointment History -->
            <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                <Label text="📖 Recent Service History" textFill="#12372a">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <ScrollPane fitToWidth="true" maxHeight="250.0" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <VBox fx:id="historyContainer" spacing="10.0">
                        <!-- History items will be added dynamically -->
                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- Loyalty Points Card -->
            <HBox alignment="CENTER" spacing="20.0" style="-fx-background-color: linear-gradient(to right, #12372a, #1db954); -fx-background-radius: 10; -fx-padding: 20;">
                <VBox alignment="CENTER" spacing="5.0">
                    <Label text="🏆 Loyalty Points" textFill="#f0fdf4">
                        <font>
                            <Font name="System Bold" size="16.0" />
                        </font>
                    </Label>
                    <Label fx:id="loyaltyPointsLabel" text="250" textFill="#86efac">
                        <font>
                            <Font name="System Bold" size="24.0" />
                        </font>
                    </Label>
                </VBox>
                <Separator orientation="VERTICAL" />
                <VBox spacing="3.0">
                    <Label text="Keep earning points with every service!" textFill="#bbf7d0">
                        <font>
                            <Font size="12.0" />
                        </font>
                    </Label>
                    <Label text="100 points = 5% discount on next service" textFill="#ecfdf5">
                        <font>
                            <Font size="11.0" />
                        </font>
                    </Label>
                </VBox>
            </HBox>

        </VBox>
    </ScrollPane>

</AnchorPane>