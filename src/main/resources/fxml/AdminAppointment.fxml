<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" stylesheets="@../css/AppointmentCards.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.carservicecenter_ds.controllers.adminAppointmentController">

   <children>
      <!-- Header Section -->
      <BorderPane VBox.vgrow="NEVER">
         <left>
            <HBox alignment="CENTER_LEFT" prefHeight="100.0">
               <children>
                  <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Appointments" />
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" top="20.0" />
               </padding>
            </HBox>
         </left>
      </BorderPane>

      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS" styleClass="mechanicScrollpane">
         <content>
            <FlowPane fx:id="AppointmentRoot" hgap="20.0" minHeight="400.0" prefWidth="800.0" vgap="20.0">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </FlowPane>
         </content>
      </ScrollPane>
   </children>
</VBox>
