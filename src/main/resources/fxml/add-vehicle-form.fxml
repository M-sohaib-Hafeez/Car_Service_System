<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="400.0" style="-fx-background-color: #f9fafb;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.carservicecenter_ds.controllers.AddVehicleController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <Label text="Add New Vehicle" textFill="#111827">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>

            <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 1);">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <!-- License Plate -->
                  <VBox spacing="5.0">
                     <Label text="License Plate" textFill="#374151">
                        <font>
                           <Font name="System Bold" size="13.0" />
                        </font>
                     </Label>
                     <TextField fx:id="licensePlateField" promptText="e.g. ABC-123" />
                  </VBox>

                  <!-- Type -->
                  <VBox spacing="5.0">
                     <Label text="Vehicle Type" textFill="#374151">
                        <font>
                           <Font name="System Bold" size="13.0" />
                        </font>
                     </Label>
                     <ComboBox fx:id="vehicleTypeComboBox" maxWidth="Infinity" promptText="Select type" />
                  </VBox>

                  <!-- Make & Model Row -->
                  <HBox spacing="15.0">
                     <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Make" textFill="#374151">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                        <TextField fx:id="makeField" promptText="e.g. Toyota" />
                     </VBox>
                     <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Model" textFill="#374151">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                        <TextField fx:id="modelField" promptText="e.g. Camry" />
                     </VBox>
                  </HBox>

                  <!-- Year -->
                  <VBox spacing="5.0">
                     <Label text="Year" textFill="#374151">
                        <font>
                           <Font name="System Bold" size="13.0" />
                        </font>
                     </Label>
                     <TextField fx:id="yearField" promptText="e.g. 2020" />
                  </VBox>
               </children>
            </VBox>

            <Label fx:id="errorLabel" textFill="#dc2626" visible="false" wrapText="true" />

            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <Button mnemonicParsing="false" onAction="#handleCancel" style="-fx-background-color: transparent; -fx-text-fill: #6b7280;" text="Cancel" />
               <Button mnemonicParsing="false" onAction="#handleAddVehicle" style="-fx-background-color: #12372a; -fx-text-fill: white; -fx-background-radius: 5;" text="Add Vehicle">
                  <font>
                     <Font name="System Bold" size="13.0" />
                  </font>
                  <padding>
                     <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
                  </padding>
               </Button>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>